# Copy to .env and edit. Loaded by start.sh / vllm_start.sh / status.sh.
# Anything not set here falls back to the defaults baked into the scripts.

# Path to the camera/classifier config file.
FRAUD_CONFIG=./config.yaml

# Where the FastAPI dashboard listens (must NOT collide with v1=3900,
# v2=3901, validator_app=39003, ollama=11434, open_webui=3000).
APP_PORT=3902

# Where vLLM listens (must NOT collide with ollama on 11434, etc.).
VLLM_PORT=8001
VLLM_URL=http://localhost:8001

# Logging level for the app. Same names as Python logging.
LOG_LEVEL=INFO

# Where downloaded model weights live, relative to the project root.
MODEL_DIR=./models

# vLLM tuning knobs (override at will).
VLLM_GPU_MEM_FRAC=0.85
VLLM_MAX_MODEL_LEN=16384

# Optional: override the served model id. The local snapshot under
# $MODEL_DIR/gemma is preferred when present, otherwise vLLM downloads.
GEMMA_MODEL_NAME=bg-digitalservices/Gemma-4-26B-A4B-it-NVFP4
GEMMA_LOCAL_DIR=./models/gemma

# Falcon model id (passed to setup.py / install.sh weight prefetch).
FALCON_MODEL=tiiuae/Falcon-Perception

# Log file paths (overrideable). Defaults match what status.sh shows.
APP_LOG=./logs/app.log
VLLM_LOG=./logs/vllm.log
APP_PID_FILE=./run/app.pid
PID_FILE=./run/vllm.pid

# Health-check budget for vllm_start.sh (large NVFP4 model loads slowly).
HEALTH_TIMEOUT_SEC=900
