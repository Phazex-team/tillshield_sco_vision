# Backups produced by this refactor
sco_vision.backup.*.tar.gz

# Offline model bundle: hardlinks into ~/.cache. Each operator prepares
# their own via scripts/prepare_offline_model_bundle.py. The README,
# offline_assets.yaml registry, and models/manifest.json ARE tracked so
# the destination machine can verify after rsync/tar from a prepared
# repo. The 100+GB of weights themselves are not.
models/hf/
# Wheelhouse holds ~2.7 GB of binary wheels (sam2 + torch + cuda) needed
# for an offline install. The repo tracks the manifest.json so verify
# scripts can confirm coverage on the destination; the wheel files
# themselves travel via tar/rsync, not git.
wheelhouse/*
!wheelhouse/manifest.json
!models/README.md
!models/manifest.json
